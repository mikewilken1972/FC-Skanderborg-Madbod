rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /events/{eventId} {
      allow read, write: if true;
    }

    match /days/{dayId} {
      allow read, write: if true;
    }

    match /shifts/{shiftId} {
      allow read, write: if true;
    }

    match /tasks/{taskId} {
      allow read, write: if true;
    }
  }
}
